doctype html
html(lang="id")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="description", content="Sistem Pendukung Keputusan Properti menggunakan metode Simple Additive Weighting (SAW)")
    title= title || 'SPK Properti | Metode SAW'
    link(rel="stylesheet", href="/css/style.css")
  body
    .app-container

      header.app-header
        h1.app-header__title Sistem Pendukung Keputusan Properti Menggunakan Metode SAW
        

      .grid-2col

        .glass-card
          .card-head
            .card-head__left
              .step-badge.step-badge--teal 1
              div
                .card-head__title Kriteria &amp; Bobot
                .card-head__subtitle Tambahkan kriteria penilaian
            .btn.btn--add#addKriteria
              span + Tambah
          .card-body
            table.data-table#tableKriteria
              thead
                tr
                  th Nama Kriteria
                  th Sifat
                  th Bobot (%)
                  th.text-end Aksi
              tbody
            .bobot-indicator#bobotIndicator
              span Total Bobot:&nbsp;
              span.bobot-indicator__value#bobotValue 0%

        .glass-card
          .card-head
            .card-head__left
              .step-badge.step-badge--green 2
              div
                .card-head__title Alternatif (Properti)
                .card-head__subtitle Daftar properti yang akan dinilai
            .btn.btn--add#addAlternatif
              span + Tambah
          .card-body
            table.data-table#tableAlternatif
              thead
                tr
                  th Nama Properti
                  th.text-end Aksi
              tbody

      .grid-full
        .glass-card
          .card-head
            .card-head__left
              .step-badge.step-badge--dark 3
              div
                .card-head__title Matriks Keputusan
                .card-head__subtitle Masukkan nilai setiap alternatif terhadap kriteria
          .card-body
            .table-wrap
              table.data-table#tableMatrix
                thead
                  tr
                    th Alternatif / Kriteria
                tbody

      .grid-full
        .glass-card
          .card-head
            .card-head__left
              .step-badge.step-badge--purple 4
              div
                .card-head__title Matriks Normalisasi (R)
          .card-body
            .table-wrap
              table.data-table#tableNormalisasi
                thead
                  tr
                    th Alternatif / Kriteria
                tbody

      .grid-full
        .glass-card
          .card-head
            .card-head__left
              .step-badge.step-badge--amber 5
              div
                .card-head__title Matriks Perangkingan (V)
          .card-body
            .table-wrap
              table.data-table#tablePerangkingan
                thead
                  tr
                    th Alternatif / Kriteria
                    th.text-center Total (V)
                tbody

      .action-section
        button.btn.btn--primary#btnHitung(type="button") Hitung SAW

      #hasilSection.result-section
        .grid-full
          .glass-card.glow-pulse
            .card-head
              .card-head__left
                .step-badge.step-badge--teal ★
                div
                  .card-head__title Hasil Perangkingan
            .card-body
              .table-wrap
                table.data-table#tableHasil
                  thead
                    tr
                      th.text-center Rank
                      th Nama Properti
                      th.text-center Nilai V
                  tbody

      footer.app-footer
        p SPK Properti — Metode SAW &nbsp;·&nbsp; #{new Date().getFullYear()}

    script(src="/js/script.js")